{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ArcX",
  "description": "ArcX splits perp DEX trading strategies into separately tradeable tokens: one for USDC returns, one for exchange points.",
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo/arc-logo.png",
    "dark": "/logo/arc-logo.png",
    "href": "https://arcx.trade"
  },
  "colors": {
    "primary": "#40C873",
    "light": "#4DD88A",
    "dark": "#40C873"
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#0A0A0A"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "mermaid": {},
  "styling": {
    "eyebrows": "breadcrumbs",
    "latex": true,
    "codeblocks": "dark"
  },
  "navbar": {
    "links": [
      {
        "label": "Twitter",
        "href": "https://x.com/arcxtrade"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://app.arcx.trade"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt"
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Learn",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "learn/protocol-overview",
              "learn/epoch-lifecycle"
            ]
          },
          {
            "group": "Tokens",
            "pages": [
              "learn/strategy-token",
              "learn/expected-points-token",
              "learn/points-token"
            ]
          },
          {
            "group": "Using ArcX",
            "pages": [
              "learn/user-guide",
              "learn/pendle-comparison"
            ]
          }
        ]
      },
      {
        "tab": "Strategies",
        "groups": [
          {
            "group": "Strategies",
            "pages": [
              "strategies/bluechip-funding-arb",
              "strategies/long-bitcoin"
            ]
          }
        ]
      },
      {
        "tab": "Deep Dives",
        "groups": [
          {
            "group": "Technical Analysis",
            "pages": [
              "deep-dives/credit-mathematics",
              "deep-dives/ept-pricing",
              "deep-dives/trust-model-and-security"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "reference/glossary-and-reference"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/arcxtrade"
    }
  }
}
